parameters
{
    albedo_map  texture("white")
    normal_map   texture("normal_up")
    specular_map texture("black")
    occlusion_map texture("white")
	color        Vec4(1.0,1.0,1.0,1.0)
    shininess    float(16.0)
    
    mask         float(-1.0)
    mask_shadow  float(-1.0)
}

sub_effect
{	
	//import shadow forward
    technique "forward"
    {
        pass 
        {
            zbuffer less
            blend off
            cullface back
            lights only_ambient
            shader source 
            {
				#define FORWARD_RENDERING
				#include "Legacy.hlsl"
            }
        }
        pass 
        {
            zbuffer equal
            blend one one  
            cullface back
            lights spot_point_direction
			shadows spot_point_direction
            shader source 
            {
                #define FORWARD_RENDERING
				#include "Legacy.hlsl"
            }
		}
    }
	//import shadow caster
	import <CastShadow> 
}
